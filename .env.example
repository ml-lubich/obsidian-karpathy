# Optional runtime defaults
OKG_VAULT_PATH=examples/demo-vault
OKG_HOST=127.0.0.1
OKG_PORT=8765

# LLM Integration — choose ONE provider (or leave both blank to disable AI chat)

# --- Option A: Anthropic Claude (recommended) ---
ANTHROPIC_API_KEY=
# LLM_PROVIDER=anthropic
# OPENAI_MODEL=claude-3-5-sonnet-20241022

# --- Option B: OpenAI or OpenAI-compatible API ---
OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1   # OpenAI default
# OPENAI_BASE_URL=http://localhost:11434/v1    # Ollama local
# OPENAI_BASE_URL=https://api.groq.com/openai/v1  # Groq
OPENAI_MODEL=gpt-4o-mini

# Auto-detect: if ANTHROPIC_API_KEY is set, Claude is used automatically.
# Set LLM_PROVIDER=openai to force OpenAI even when ANTHROPIC_API_KEY exists.
