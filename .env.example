# Optional runtime defaults
OKG_VAULT_PATH=examples/demo-vault
OKG_HOST=127.0.0.1
OKG_PORT=8765

# LLM Integration — any provider works. Leave everything blank to disable AI chat.

# --- Option A (recommended): generic OpenAI-compatible endpoint ---
# Works with Ollama, LM Studio, Groq, OpenRouter, Mistral, DeepSeek, OpenAI, ...
# Keyless local servers (Ollama, LM Studio) need NO api key.
# LLM_BASE_URL=http://localhost:11434/v1          # Ollama local (keyless)
# LLM_BASE_URL=https://api.groq.com/openai/v1     # Groq
# LLM_BASE_URL=https://openrouter.ai/api/v1       # OpenRouter
# LLM_MODEL=llama3.2
# LLM_API_KEY=

# --- Option B: OpenAI ---
OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# --- Option C: Anthropic Claude ---
ANTHROPIC_API_KEY=
# LLM_PROVIDER=anthropic

# Precedence: generic LLM_* vars win; otherwise Claude is auto-used when
# ANTHROPIC_API_KEY is set. Set LLM_PROVIDER=openai to force OpenAI.
